# ------------------------------------------------------------
# Sensitive / secrets
# ------------------------------------------------------------
# Never commit API keys or credentials
.env
.env.*
*.key
secrets/
api_keys.txt

# ------------------------------------------------------------
# Generated by the apps (will be recreated on each run)
# ------------------------------------------------------------
benchmark_app/vector_db/
benchmark_app/documents/
benchmark_app/runs/
benchmark_app/backups/
**/vector_db/
**/documents/
**/runs/
**/backups/

# Streamlit cache
.streamlit/
**/.streamlit/secrets.toml

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
env/
ENV/
.venv/
.env/
pip-log.txt
pip-delete-this-directory.txt

# Testing & coverage
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/
htmlcov/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# ------------------------------------------------------------
# Data files (often too large for git; use Git LFS if needed)
# ------------------------------------------------------------
*.pdf
*.csv.large
*.parquet
*.feather
*.h5
*.nc
*.tif
*.tiff
data/raw/
data/processed/
data/external/

# But keep small reference docs in docs/ folder
!docs/**/*.pdf

# ------------------------------------------------------------
# Model files (typically large)
# ------------------------------------------------------------
*.pkl
*.joblib
*.bin
models/
checkpoints/

# Hugging Face cache (sentence-transformers downloads here)
.cache/huggingface/

# ------------------------------------------------------------
# IDE / editor
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject

# ------------------------------------------------------------
# OS-specific
# ------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msm
*.msp

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
*.log
logs/
